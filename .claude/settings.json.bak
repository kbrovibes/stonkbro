{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$TOOL_INPUT\" | grep -q \"BACKLOG.md\"; then bash scripts/backlog-hook.sh; fi'"
          }
        ]
      }
    ]
  }
}
